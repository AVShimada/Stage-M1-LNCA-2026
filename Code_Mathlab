%code création de groupe en fonction des quantiles

N = 49;
ages = zeros(N,1);

for i = 1:N
    SUBJECT = eval(sprintf('SUBJECT_%d', i));
    ages(i) = SUBJECT.age;
end

q = quantile(ages, [0.25 0.5 0.75]);

groups = zeros(N,1);

for i = 1:N
    
    if ages(i) <= q(1)
        groups(i) = 1;
    elseif ages(i) <= q(2)
        groups(i) = 2;
    elseif ages(i) <= q(3)
        groups(i) = 3;
    else
        groups(i) = 4;
    end
    
end

for i = 1:N
    
    SUBJECT = eval(sprintf('SUBJECT_%d', i));
    
    SUBJECT.quartile = groups(i);
    
    eval(sprintf('SUBJECT_%d = SUBJECT;', i));
    
end

for k = 1:4
    fprintf('Quartile %d : %d sujets\n', k, sum(groups==k));
end

%Code afficher la connectivité moyenne strucutrale et fonctionnelle pour chaque groupe : 
N = 49;

for k = 1:4
    
    FC_mean = zeros(68,68);
    SC_mean = zeros(68,68);
    count = 0;
    
    for i = 1:N
        
        if groups(i) == k
            
            SUBJECT = eval(sprintf('SUBJECT_%d', i));
            
            FC_mean = FC_mean + SUBJECT.FC;
            SC_mean = SC_mean + SUBJECT.SC;
            
            count = count + 1;
            
        end
        
    end
    
    FC_mean = FC_mean / count;
    SC_mean = SC_mean / count;
    
    % FC
    figure;
    imagesc(FC_mean);
    colorbar;
    clim([-1 1]);
    axis square;
    title(['FC moyenne - Quartile ' num2str(k)]);
    
    % SC en LOG
    figure;
    imagesc(log(SC_mean));
    colorbar;
    axis square;
    title(['SC moyenne (log) - Quartile ' num2str(k)]);
    
end
